<?xml version="1.0"?>
<!DOCTYPE module PUBLIC "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <!-- TreeWalker module for checking various code style violations -->
    <module name="TreeWalker">

        <!-- Avoid wildcard imports -->
        <module name="AvoidStarImport"/>

        <!-- Ensure methods have Javadoc -->
        <module name="JavadocMethod">
            <!-- Minimum number of lines required for Javadoc (optional, can be adjusted) -->
            <property name="minLines" value="2"/>
        </module>

        <!-- Ensure classes and interfaces have Javadoc -->
        <module name="JavadocType">
            <property name="minLines" value="2"/>
        </module>

        <!-- Enforce method name style (camelCase) -->
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Enforce class and interface name style (CamelCase) -->
        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Enforce no magic numbers in the code -->
        <module name="MagicNumber">
            <property name="ignoreNumbers" value="0,1,100"/>
        </module>

        <!-- Enforce proper indentation (2 spaces in this case) -->
        <module name="Indentation">
            <property name="indent" value="2"/>
        </module>

        <!-- Enforce no empty catch blocks -->
        <module name="EmptyCatchBlock"/>

        <!-- Enforce variable naming conventions (camelCase) -->
        <module name="LocalVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Enforce no unused imports -->
        <module name="UnusedImports"/>
    </module>

    <!-- Additional global rules -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package|^import|^//.*$"/>
    </module>

    <!-- Enforce that curly braces must be placed on the same line as the statement -->
    <module name="OneTopLevelClass">
        <property name="allowInnerClass" value="false"/>
    </module>

    <!-- Enforce no nested comments -->
    <module name="NestedForDepth">
        <property name="max" value="3"/>
    </module>
</module>
